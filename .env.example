# OpenRouter (required for AI chat)
OPENROUTER_API_KEY=

# Session signing (required when ENV=production)
SESSION_SECRET=change-me-in-production

# production | development
ENV=development

# Mail provider: console (logs only) | resend | smtp
# For real emails set MAIL_PROVIDER=resend and fill RESEND_API_KEY below.
MAIL_PROVIDER=console
MAIL_FROM=onboarding@resend.dev

# Resend (when MAIL_PROVIDER=resend)
# Get your API key at https://resend.com/api-keys
# MAIL_FROM must be a verified sender (onboarding@resend.dev works for testing)
RESEND_API_KEY=

# SMTP (when MAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
